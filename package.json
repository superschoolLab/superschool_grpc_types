{
  "name": "@superschool/grpc-types",
  "version": "0.1.0",
  "description": "SuperSchool gRPC proto definitions and auto-generated TypeScript types",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist/",
    "proto/"
  ],
  "scripts": {
    "generate": "bash scripts/generate.sh",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run generate && npm run build"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.0.0"
  },
  "peerDependencies": {
    "@grpc/grpc-js": ">=1.10.0",
    "@nestjs/microservices": ">=10.0.0",
    "rxjs": ">=7.0.0"
  },
  "devDependencies": {
    "@grpc/grpc-js": "^1.14.0",
    "@nestjs/microservices": "^11.1.0",
    "rxjs": "^7.8.0",
    "ts-proto": "^2.6.1",
    "typescript": "^5.7.0"
  }
}
